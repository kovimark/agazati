<Window x:Class="hegyekWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hegyekWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="91*"/>
            <ColumnDefinition Width="69*"/>
        </Grid.ColumnDefinitions>
        <DataGrid x:Name="dataGrid"/>
        <Label Grid.Column="1" Content="Név:" HorizontalAlignment="Left" Margin="48,57,0,0" VerticalAlignment="Top"/>

        <Label Grid.Column="1" Content="Hegység" HorizontalAlignment="Left" Margin="46,109,0,0" VerticalAlignment="Top"/>
        <Label Grid.Column="1" Content="Magasság" HorizontalAlignment="Left" Margin="48,168,0,0" VerticalAlignment="Top"/>
        <TextBox Grid.Column="1" Name="nevBox" HorizontalAlignment="Left" Margin="129,61,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox Grid.Column="1" Name="hegysegBox" HorizontalAlignment="Left" Margin="129,113,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox Grid.Column="1" Name="magassagBox" HorizontalAlignment="Left" Margin="129,172,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <Button Grid.Column="1" Content="Hozzáad" HorizontalAlignment="Left" Margin="189,217,0,0" VerticalAlignment="Top" Click="addButton"/>
        <Button Grid.Column="1" Content="Mentés" HorizontalAlignment="Left" Margin="194,259,0,0" VerticalAlignment="Top" Click="saveButton"/>

    
    </Grid>
</Window>
